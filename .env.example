VITE_TRACKMIND_API_BASE_URL=/api/v1

# This repository deploys the platform UI as a Vite-only static frontend.
# For hosted deployments, set this to the public HTTPS API URL, including /api/v1.
# The default /api/v1 value is only for local Vite proxy development with
# `npm run start:api` running separately on http://127.0.0.1:4000.
# Example:
# VITE_TRACKMIND_API_BASE_URL=https://trackmind-api.example.com/api/v1
