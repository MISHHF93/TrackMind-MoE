# TrackMind Nexus canonical environment model.
# Do not add service-specific aliases for the same concept.

# Frontend API adapter.
# Local Vite proxy default. Hosted static deployments must use the public API URL including /api/v1.
VITE_TRACKMIND_API_BASE_URL=/api/v1
# VITE_TRACKMIND_API_BASE_URL=https://trackmind-api.example.com/api/v1

# API runtime.
HOST=127.0.0.1
PORT=4000

# Smoke/performance checks.
TRACKMIND_PERF_BASE_URL=http://127.0.0.1:4000/api/v1
TRACKMIND_PERF_REQUESTS=20
TRACKMIND_PERF_CONCURRENCY=4

# Local PostgreSQL baseline for Docker Compose and Azure parameter examples.
TRACKMIND_PG_ADMIN_PASSWORD=change-me-only-for-local-dev

# Azure/IaC deployment parameters. These are consumed by deployment tooling, not the local API facade.
AZURE_ENV_NAME=dev
AZURE_LOCATION=eastus
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_CONTAINER_ENV_NAME=
AZURE_API_IMAGE=ghcr.io/trackmind/nexus-api:dev
AZURE_AGENTS_IMAGE=ghcr.io/trackmind/nexus-agents:dev

# Agent/provider credentials. Leave empty unless a real provider integration is implemented and licensed.
TRACKMIND_AGENT_CONFIG=apps/agents/router/config.json
TRACKMIND_PROVIDER_API_KEY=
