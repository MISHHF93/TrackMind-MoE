{
  "name": "@trackmind/frontend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm --prefix ../../packages/shared run build",
    "build": "tsc -p tsconfig.json && vite build",
    "pretypecheck": "npm --prefix ../../packages/shared run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prestart": "npm --prefix ../../packages/shared run build",
    "start": "vite --host 127.0.0.1 --port 5173",
    "test": "node tests/frontend-contracts.test.mjs && node tests/route-inventory.test.mjs && node tests/role-route-access.test.mjs && node tests/platform-verification.test.mjs && node tests/compliance-wiring.test.mjs && node tests/wave-03-route-architecture.test.mjs && node tests/wave-02-design-system.test.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@tanstack/react-query": "5.90.12",
    "@trackmind/shared": "file:../../packages/shared",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.561.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.10.1",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.18",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "tailwindcss": "4.1.18",
    "vite": "8.0.16"
  }
}
